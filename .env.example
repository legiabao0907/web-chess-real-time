# ============================================
# Docker Compose Environment Variables (TEMPLATE)
# Copy to .env and fill in your real secrets
# ============================================

# --- PostgreSQL ---
POSTGRES_DB=testnest
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME

# --- Backend ---
DATABASE_URL=postgres://CHANGE_USER:CHANGE_PASS@postgres:5432/CHANGE_DB
REDIS_HOST=redis
REDIS_PORT=6379
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHAR
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHAR
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:4000
PORT=8080

# --- Frontend (build-time args) ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# --- Host Ports ---
# Change FRONTEND_HOST_PORT if port 4000 is in use on your VPS
# Set POSTGRES_HOST_PORT / REDIS_HOST_PORT to "" to not expose to host (recommended for production)
FRONTEND_HOST_PORT=4000
BACKEND_HOST_PORT=8080
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380
